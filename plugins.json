{
  "_readme": "Machine-readable plugin registry for this firmware. IDs reflect registration order in src/main.cpp (starting at 1). IDs are stable as long as plugins are only appended; inserting in the middle will shift IDs of all subsequent plugins. Always append new plugins at the END of each registration block to avoid breaking existing integrations. The device exposes the live id↔name mapping at GET /api/info (see 'api_contract' below).",
  "id_assignment": "sequential, 1-based, determined by addPlugin() call order in src/main.cpp",
  "api_contract": {
    "live_plugin_list": "GET http://<device-ip>/api/info  →  JSON: { plugins: [ { id: number, name: string }, ... ] }",
    "set_active_plugin": "WebSocket → send JSON: { event: 'plugin', plugin: <id> }",
    "set_active_plugin_http": "PATCH http://<device-ip>/api/plugin?id=<id>",
    "websocket_state": "WS connects to ws://<device-ip>/ws — on connect, receives full state including 'plugin' (active id) and 'plugins' array"
  },
  "note_on_ha_addon": "For the Home Assistant addon plugin picker: prefer querying /api/info at runtime so the picker is always in sync with the actual firmware. If you must hardcode options, use this file as the source of truth and keep names identical to the 'name' field below.",
